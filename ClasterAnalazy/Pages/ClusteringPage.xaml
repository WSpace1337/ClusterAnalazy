<Page x:Class="ClusterVisualizer.Pages.ClusteringPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:oxy="clr-namespace:OxyPlot.Wpf;assembly=OxyPlot.Wpf"
      Title="ClusteringPage">

    <Grid Margin="10" Background="#F1F5F9">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="480"/>
        </Grid.ColumnDefinitions>

        <!-- Основная часть -->
        <Grid Grid.Column="0" Margin="0 0 10 0">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Карточка панели управления -->
            <Border Grid.Row="0"
                    Background="White"
                    CornerRadius="12"
                    Padding="12"
                    Margin="0 0 0 10"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1">

                <StackPanel x:Name="ControlsPanel"
                            Orientation="Horizontal">

                    <Button Content="📂 Load CSV"
                            Width="120"
                            Margin="0 0 10 0"
                            Click="LoadData_Click"/>

                    <Button Content="⚙ Run Clustering"
                            Width="140"
                            Margin="0 0 10 0"
                            Click="RunClustering_Click"/>

                    <Button Content="🦄Find Best K (Silhouette)"
                            Click="FindBestK_Click"/>

                    <StackPanel x:Name="KControlsPanel"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="0 0 10 0">

                        <TextBlock Text="Clusters:"
                                   VerticalAlignment="Center"
                                   Margin="10 0 5 0"/>

                        <TextBox x:Name="ClusterCountBox"
                                 Width="50"
                                 Text="3"/>
                    </StackPanel>

                    <StackPanel x:Name="DbscanControlsPanel"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="0 0 10 0"
                                Visibility="Collapsed">

                        <TextBlock Text="eps:"
                                   VerticalAlignment="Center"
                                   Margin="10 0 5 0"/>

                        <TextBox x:Name="EpsBox"
                                 Width="70"
                                 Text="0.05"
                                 Margin="10 0 10 0"/>

                        <TextBlock Text="minPts:"
                                   VerticalAlignment="Center"
                                   Margin="10 0 5 0"/>

                        <TextBox x:Name="MinPtsBox"
                                 Width="50"
                                 Text="4"
                                 Margin="0 0 10 0"/>

                        <Button Content="Find EPS"
                                Width="100"
                                Click="FindEps_Click"/>
                    </StackPanel>

                    <TextBlock Text="Algorithm:"
                               VerticalAlignment="Center"
                               Margin="10 0 5 0"/>

                    <ComboBox x:Name="AlgorithmBox"
                              Width="160"
                              SelectionChanged="AlgorithmBox_SelectionChanged"/>

                    <Button x:Name="DendrogramButton"
                            Content="Show Dendrogram"
                            Width="130"
                            Margin="15 0 0 0"
                            Click="ShowDendrogram_Click"
                            Visibility="Collapsed"/>

                </StackPanel>

            </Border>

            <!-- Карточка графика -->
            <Border Grid.Row="1"
                    Background="White"
                    CornerRadius="12"
                    Padding="10"
                    Margin="0 0 0 10"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1">

                <oxy:PlotView x:Name="PlotView"/>

            </Border>

            <!-- Нижняя панель -->
            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ProgressBar x:Name="ProgressBar"
                             Height="20"
                             Margin="5"
                             Grid.Row="0"
                             Visibility="Collapsed"
                             IsIndeterminate="True"/>

                <TextBlock x:Name="StatusText"
                           FontSize="16"
                           Grid.Row="1"
                           Text="Ready"
                           FontStyle="Italic"
                           Margin="5"/>
            </Grid>

        </Grid>

        <!-- Карточка логов справа -->
        <Border Grid.Column="1"
                Background="White"
                CornerRadius="12"
                Padding="12"
                Margin="10 0 0 0"
                BorderBrush="#E2E8F0"
                BorderThickness="1">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Logs"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0 0 0 10"/>

                <TextBox x:Name="LogBox"
                         Grid.Row="1"
                         Margin="0"
                         IsReadOnly="True"
                         TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="12"
                         Background="#F8FAFC"
                         BorderBrush="#E2E8F0"
                         BorderThickness="1"/>
            </Grid>

        </Border>

    </Grid>

</Page>