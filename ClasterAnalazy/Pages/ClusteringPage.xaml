<Page x:Class="ClusterVisualizer.Pages.ClusteringPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:oxy="clr-namespace:OxyPlot.Wpf;assembly=OxyPlot.Wpf"
      Title="ClusteringPage">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        

        <!-- Панель управления -->
        <StackPanel x:Name="ControlsPanel" Orientation="Horizontal" Margin="0 0 0 10">
            

            <Button Content="📂 Load CSV"
                    Width="120"
                    Margin="0 0 10 0"
                    Click="LoadData_Click"/>

            <Button Content="⚙ Run Clustering"
                    Width="140"
                    Margin="0 0 10 0"
                    Click="RunClustering_Click"/>
            
            <Button Content="🦄Find Best K (Silhouette)"
        Click="FindBestK_Click"/>

            <!-- KMeans / Hierarchical -->
            <StackPanel x:Name="KControlsPanel"
                Orientation="Horizontal"
                VerticalAlignment="Center"
                Margin="0 0 10 0">

                <TextBlock Text="Clusters:"
                   VerticalAlignment="Center"
                   Margin="10 0 5 0"/>

                <TextBox x:Name="ClusterCountBox"
                 Width="50"
                 Text="3"/>
            </StackPanel>

            <!-- DBSCAN -->
            <StackPanel x:Name="DbscanControlsPanel"
                Orientation="Horizontal"
                VerticalAlignment="Center"
                Margin="0 0 10 0"
                Visibility="Collapsed">

                <TextBlock Text="eps:"
                   VerticalAlignment="Center"
                   Margin="10 0 5 0"/>

                <TextBox x:Name="EpsBox"
                 Width="70"
                 Text="0.05"
                 Margin="10 0 10 0"/>

                <TextBlock Text="minPts:"
                   VerticalAlignment="Center"
                   Margin="10 0 5 0"/>

                <TextBox x:Name="MinPtsBox"
                 Width="50"
                 Text="4"
                 Margin="0 0 10 0"/>

                <Button Content="Find EPS"
                Width="100"
                Click="FindEps_Click"/>
            </StackPanel>

            <!-- Выбор алгоритма -->
            <TextBlock Text="Algorithm:"
               VerticalAlignment="Center"
               Margin="10 0 5 0"/>

            <ComboBox x:Name="AlgorithmBox"
              Width="160"
              SelectionChanged="AlgorithmBox_SelectionChanged"/>

            <!-- Только для Hierarchical -->
            <Button x:Name="DendrogramButton"
            Content="Show Dendrogram"
            Width="130"
            Margin="15 0 0 0"
            Click="ShowDendrogram_Click"
            Visibility="Collapsed"/>

        </StackPanel>
        

        <!-- График -->
        <oxy:PlotView x:Name="PlotView"
                      Grid.Row="1"/>
        
        <ProgressBar x:Name="ProgressBar"
             Height="20"
             Margin="5"
             Grid.Row="2"
             Visibility="Collapsed"
             IsIndeterminate="True"/>

        <!-- Статус -->
        <TextBlock x:Name="StatusText"
                   FontSize="16"
                   Grid.Row="2"
                   Text="Ready"
                   FontStyle="Italic"
                   Margin="5"/>
        

    </Grid>

</Page>