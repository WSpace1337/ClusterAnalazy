<Page x:Class="ClusterVisualizer.Pages.ElbowPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:oxy="clr-namespace:OxyPlot.Wpf;assembly=OxyPlot.Wpf">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Панель управления -->

        
        <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
            
            <TextBlock Text="Max K:"
                       VerticalAlignment="Center"
                       Margin="10 0 5 0"/>
            
            <TextBox x:Name="MaxKBox"
                     Width="50"
                     Text="10"/>


            <Button Content="Calculate Elbow"
                    Width="150"
                    Margin="10 0"
                    Click="CalculateElbow_Click"/>

        </StackPanel>

        <!-- График -->
        <oxy:PlotView x:Name="PlotView"
                      Grid.Row="1"/>

        <!-- Статус -->
        <TextBlock x:Name="StatusText"
                   Grid.Row="2"
                   FontSize="16"
                   Text="Ready"
                   Margin="5"
                   FontStyle="Italic"/>

    </Grid>

</Page>