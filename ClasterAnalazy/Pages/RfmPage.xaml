<Page x:Class="ClusterVisualizer.Pages.RfmPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="10" Background="#F1F5F9">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                CornerRadius="12"
                Padding="16"
                Margin="0 0 0 10"
                BorderBrush="#E2E8F0"
                BorderThickness="1">

            <StackPanel Orientation="Horizontal">

                <TextBlock Text="RFM Analysis"
                           FontSize="24"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="0 0 20 0"/>

                <Button Content="Load RFM CSV"
                        Width="130"
                        Height="34"
                        Click="LoadRfm_Click"/>

                <TextBlock x:Name="StatusText"
                           Text="Ready"
                           Foreground="Gray"
                           FontStyle="Italic"
                           VerticalAlignment="Center"
                           Margin="20 0 0 0"/>

            </StackPanel>

        </Border>

        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="12"
                    Padding="16"
                    Margin="0 0 10 0"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="RFM Customers"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0 0 0 10"/>

                    <DataGrid x:Name="RfmGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              ColumnWidth="*">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="CustomerId" Binding="{Binding CustomerId}" Width="*"/>
                            <DataGridTextColumn Header="Recency" Binding="{Binding Recency}" Width="*"/>
                            <DataGridTextColumn Header="Frequency" Binding="{Binding Frequency}" Width="*"/>
                            <DataGridTextColumn Header="Monetary" Binding="{Binding Monetary}" Width="*"/>
                            <DataGridTextColumn Header="R" Binding="{Binding RScore}" Width="60"/>
                            <DataGridTextColumn Header="F" Binding="{Binding FScore}" Width="60"/>
                            <DataGridTextColumn Header="M" Binding="{Binding MScore}" Width="60"/>
                            <DataGridTextColumn Header="RFM" Binding="{Binding RfmScore}" Width="90"/>
                            <DataGridTextColumn Header="Total" Binding="{Binding TotalScore}" Width="80"/>
                            <DataGridTextColumn Header="Segment" Binding="{Binding Segment}" Width="*"/>
                        </DataGrid.Columns>

                    </DataGrid>
                </Grid>

            </Border>

            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="12"
                    Padding="16"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Segment Summary"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0 0 0 10"/>

                    <ListBox x:Name="SegmentSummaryList"
                             Grid.Row="1"/>

                </Grid>

            </Border>

        </Grid>

    </Grid>
</Page>