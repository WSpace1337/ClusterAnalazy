<Page x:Class="ClusterVisualizer.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="10" Background="#F1F5F9">

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Settings"
                           FontSize="28"
                           FontWeight="Bold"
                           Margin="10 10 0 20"/>

                <!-- General -->
                <Border Grid.Row="1"
                        Background="White"
                        CornerRadius="12"
                        Padding="20"
                        Margin="10"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1">

                    <StackPanel>

                        <TextBlock Text="General"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Margin="0 0 0 15"/>

                        <CheckBox x:Name="NormalizeCheckBox"
                                  Content="Normalize data"
                                  IsChecked="True"
                                  Margin="0 0 0 12"/>

                        <TextBlock Text="Default algorithm"/>

                        <ComboBox x:Name="DefaultAlgorithmBox"
                                  Height="32"
                                  Margin="0 5 0 12">
                            <ComboBoxItem Content="K-means"/>
                            <ComboBoxItem Content="DBSCAN"/>
                            <ComboBoxItem Content="Hierarchical"/>
                        </ComboBox>

                        <TextBlock Text="Max preview rows"/>

                        <TextBox x:Name="PreviewRowsBox"
                                 Text="10"
                                 Height="32"/>

                    </StackPanel>

                </Border>

                <!-- DBSCAN -->
                <Border Grid.Row="2"
                        Background="White"
                        CornerRadius="12"
                        Padding="20"
                        Margin="10"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1">

                    <StackPanel>

                        <TextBlock Text="DBSCAN"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Margin="0 0 0 15"/>

                        <TextBlock Text="Default eps"/>

                        <TextBox x:Name="DefaultEpsBox"
                                 Text="0.039"
                                 Height="32"
                                 Margin="0 5 0 12"/>

                        <TextBlock Text="Default minPts"/>

                        <TextBox x:Name="DefaultMinPtsBox"
                                 Text="4"
                                 Height="32"/>

                    </StackPanel>

                </Border>

                <!-- Logs / Save -->
                <Border Grid.Row="3"
                        Background="White"
                        CornerRadius="12"
                        Padding="20"
                        Margin="10"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1">

                    <StackPanel>

                        <TextBlock Text="Logs &amp; Actions"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0 0 0 15"/>

                        <Button Content="Clear logs"
                                Height="34"
                                Margin="0 0 0 10"
                                Click="ClearLogs_Click"/>

                        <Button Content="Save Settings"
                                Height="38"
                                Background="#2D3748"
                                Foreground="White"
                                FontWeight="SemiBold"
                                Click="SaveSettings_Click"/>

                        <TextBlock x:Name="StatusText"
                                   Margin="0 15 0 0"
                                   Foreground="Gray"
                                   TextWrapping="Wrap"/>

                    </StackPanel>

                </Border>

            </Grid>

        </ScrollViewer>

    </Grid>

</Page>