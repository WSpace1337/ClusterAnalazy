<Page x:Class="ClusterVisualizer.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="25">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Dashboard"
                   FontSize="28"
                   FontWeight="Bold"
                   Margin="0 0 0 20"/>

        <UniformGrid Grid.Row="1"
                     Columns="3"
                     Rows="2"
                     Margin="0 20 0 0">

            <Border Background="#F4F6F8" CornerRadius="10" Padding="20" Margin="8">
                <StackPanel>
                    <TextBlock Text="Customers" Foreground="Gray"/>
                    <TextBlock x:Name="CustomersText" FontSize="28" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Background="#F4F6F8" CornerRadius="10" Padding="20" Margin="8">
                <StackPanel>
                    <TextBlock Text="Clusters" Foreground="Gray"/>
                    <TextBlock x:Name="ClustersText" FontSize="28" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Background="#F4F6F8" CornerRadius="10" Padding="20" Margin="8">
                <StackPanel>
                    <TextBlock Text="Optimal K" Foreground="Gray"/>
                    <TextBlock x:Name="OptimalKText" FontSize="28" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Background="#F4F6F8" CornerRadius="10" Padding="20" Margin="8">
                <StackPanel>
                    <TextBlock Text="Noise Points" Foreground="Gray"/>
                    <TextBlock x:Name="NoiseText" FontSize="28" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Background="#F4F6F8" CornerRadius="10" Padding="20" Margin="8">
                <StackPanel>
                    <TextBlock Text="Average Age" Foreground="Gray"/>
                    <TextBlock x:Name="AvgAgeText" FontSize="28" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Background="#F4F6F8" CornerRadius="10" Padding="20" Margin="8">
                <StackPanel>
                    <TextBlock Text="Average Income" Foreground="Gray"/>
                    <TextBlock x:Name="AvgIncomeText" FontSize="28" FontWeight="Bold"/>
                </StackPanel>
            </Border>

        </UniformGrid>

    </Grid>
</Page>