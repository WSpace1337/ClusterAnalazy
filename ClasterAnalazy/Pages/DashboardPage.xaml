<Page x:Class="ClusterVisualizer.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="10" Background="#F1F5F9">

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Dashboard"
                           FontSize="28"
                           FontWeight="Bold"
                           Margin="10 10 0 20"/>

                <!-- Карточки статистики -->
                <UniformGrid Grid.Row="1"
                             Columns="3"
                             Rows="2"
                             Margin="0 0 0 10">

                    <Border Background="White"
                            CornerRadius="12"
                            Padding="20"
                            Margin="8"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Customers" Foreground="Gray"/>
                            <TextBlock x:Name="CustomersText"
                                       FontSize="28"
                                       FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <Border Background="White"
                            CornerRadius="12"
                            Padding="20"
                            Margin="8"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Clusters" Foreground="Gray"/>
                            <TextBlock x:Name="ClustersText"
                                       FontSize="28"
                                       FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <Border Background="White"
                            CornerRadius="12"
                            Padding="20"
                            Margin="8"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Optimal K" Foreground="Gray"/>
                            <TextBlock x:Name="OptimalKText"
                                       FontSize="28"
                                       FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <Border Background="White"
                            CornerRadius="12"
                            Padding="20"
                            Margin="8"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Noise Points" Foreground="Gray"/>
                            <TextBlock x:Name="NoiseText"
                                       FontSize="28"
                                       FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <Border Background="White"
                            CornerRadius="12"
                            Padding="20"
                            Margin="8"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Average Age" Foreground="Gray"/>
                            <TextBlock x:Name="AvgAgeText"
                                       FontSize="28"
                                       FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <Border Background="White"
                            CornerRadius="12"
                            Padding="20"
                            Margin="8"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Average Income" Foreground="Gray"/>
                            <TextBlock x:Name="AvgIncomeText"
                                       FontSize="28"
                                       FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                </UniformGrid>

                <!-- Таблица сравнения алгоритмов -->
                <Border Grid.Row="2"
                        Background="White"
                        CornerRadius="12"
                        Padding="16"
                        Margin="8"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Algorithm Comparison"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Margin="0 0 0 10"/>

                        <TextBlock x:Name="StatusText"
                                   Grid.Row="1"
                                   Text="Ready"
                                   Foreground="Gray"
                                   FontStyle="Italic"
                                   Margin="0 0 0 10"/>

                        <DataGrid x:Name="ComparisonGrid"
                                  Grid.Row="2"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  MinHeight="160"
                                  MaxHeight="220">

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Algorithm"
                                                    Binding="{Binding Algorithm}"
                                                    Width="*"/>

                                <DataGridTextColumn Header="Clusters"
                                                    Binding="{Binding Clusters}"
                                                    Width="90"/>

                                <DataGridTextColumn Header="Noise"
                                                    Binding="{Binding Noise}"
                                                    Width="90"/>

                                <DataGridTextColumn Header="Silhouette"
                                                    Binding="{Binding Silhouette, StringFormat=F4}"
                                                    Width="120"/>

                                <DataGridTextColumn Header="Davies-Bouldin"
                                                    Binding="{Binding DaviesBouldin, StringFormat=F4}"
                                                    Width="140"/>

                                <DataGridTextColumn Header="Calinski-Harabasz"
                                                    Binding="{Binding CalinskiHarabasz, StringFormat=F4}"
                                                    Width="160"/>
                            </DataGrid.Columns>

                        </DataGrid>
                    </Grid>

                </Border>

                <!-- Таблица загруженных данных -->
                <Border Grid.Row="3"
                        Background="White"
                        CornerRadius="12"
                        Padding="16"
                        Margin="8"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Loaded Data Preview"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Margin="0 0 0 10"/>

                        <DataGrid x:Name="DataPreviewGrid"
                                  Grid.Row="1"
                                  AutoGenerateColumns="True"
                                  ColumnWidth="*"
                                  HorizontalContentAlignment="Stretch"
                                  
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  MinHeight="220"
                                  MaxHeight="320"/>

                    </Grid>

                </Border>
                <!-- RFM Analytics -->
                <Border Grid.Row="4"
        Background="White"
        CornerRadius="12"
        Padding="16"
        Margin="8"
        BorderBrush="#E2E8F0"
        BorderThickness="1">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                   Text="RFM Analytics"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Margin="0 0 0 10"/>

                        <TextBlock x:Name="RfmStatusText"
                   Grid.Row="1"
                   Text="RFM data not loaded."
                   Foreground="Gray"
                   FontStyle="Italic"
                   Margin="0 0 0 10"/>

                        <DataGrid x:Name="RfmDashboardGrid"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  MinHeight="180"
                  MaxHeight="280"
                  ColumnWidth="*">

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Segment"
                                    Binding="{Binding Segment}"
                                    Width="*"/>

                                <DataGridTextColumn Header="Clients"
                                    Binding="{Binding Count}"
                                    Width="100"/>

                                <DataGridTextColumn Header="Percent"
                                    Binding="{Binding Percent}"
                                    Width="100"/>

                                <DataGridTextColumn Header="Avg R"
                                    Binding="{Binding AvgR}"
                                    Width="90"/>

                                <DataGridTextColumn Header="Avg F"
                                    Binding="{Binding AvgF}"
                                    Width="90"/>

                                <DataGridTextColumn Header="Avg M"
                                    Binding="{Binding AvgM}"
                                    Width="90"/>

                                <DataGridTextColumn Header="Avg Total"
                                    Binding="{Binding AvgTotal}"
                                    Width="120"/>
                            </DataGrid.Columns>

                        </DataGrid>

                    </Grid>

                </Border>

            </Grid>

        </ScrollViewer>
        
        

    </Grid>

</Page>